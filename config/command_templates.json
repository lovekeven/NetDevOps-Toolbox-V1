        {"cmd": "save", "desc": "保存配置（华三/华为）"},
        {"cmd": "write memory", "desc": "保存配置（Cisco）"},
        {"cmd": "copy running-config startup-config", "desc": "保存配置（Cisco）"}
      ],
      "配置恢复": [
        {"cmd": "reset saved-configuration", "desc": "清除保存的配置（华三/华为）"},
