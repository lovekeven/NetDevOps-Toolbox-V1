  "common": {
    "name": "通用命令",
    "commands": {
      "网络测试": [
        {"cmd": "ping <IP地址>", "desc": "测试网络连通性"},
        {"cmd": "traceroute <IP地址>", "desc": "追踪路由路径"},
        {"cmd": "telnet <IP地址> <端口>", "desc": "测试TCP端口连通性"}
