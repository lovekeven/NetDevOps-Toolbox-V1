{
  "h3c": {
    "name": "华三 H3C",
    "commands": {
      "系统信息": [
        {"cmd": "display version", "desc": "查看设备版本信息"},
        {"cmd": "display current-configuration", "desc": "查看当前配置"},
        {"cmd": "display saved-configuration", "desc": "查看保存的配置"},
        {"cmd": "display clock", "desc": "查看系统时间"},
        {"cmd": "display device", "desc": "查看设备信息"}
      ],
      "接口信息": [
        {"cmd": "display interface brief", "desc": "查看接口摘要"},
        {"cmd": "display interface", "desc": "查看所有接口详细信息"},
        {"cmd": "display ip interface brief", "desc": "查看IP接口摘要"},
        {"cmd": "display port trunk", "desc": "查看Trunk端口"}
      ],
      "VLAN信息": [
        {"cmd": "display vlan", "desc": "查看VLAN信息"},
        {"cmd": "display vlan brief", "desc": "查看VLAN摘要"},
        {"cmd": "display mac-address-table", "desc": "查看MAC地址表"}
      ],
      "路由信息": [
        {"cmd": "display ip routing-table", "desc": "查看路由表"},
        {"cmd": "display arp", "desc": "查看ARP表"},
        {"cmd": "display ip routing-table statistics", "desc": "查看路由统计"}
      ],
      "协议信息": [
        {"cmd": "display ospf peer", "desc": "查看OSPF邻居"},
        {"cmd": "display ospf brief", "desc": "查看OSPF摘要"},
        {"cmd": "display bgp peer", "desc": "查看BGP邻居"},
        {"cmd": "display stp brief", "desc": "查看STP摘要"},
        {"cmd": "display lldp neighbor-information", "desc": "查看LLDP邻居"}
      ],
      "性能信息": [
        {"cmd": "display cpu-usage", "desc": "查看CPU使用率"},
        {"cmd": "display memory", "desc": "查看内存使用"},
        {"cmd": "display environment", "desc": "查看环境状态（温度、电源、风扇）"}
      ],
      "安全信息": [
        {"cmd": "display acl all", "desc": "查看所有ACL"},
        {"cmd": "display user-interface", "desc": "查看用户接口"},
        {"cmd": "display local-user", "desc": "查看本地用户"}
      ]
    },
